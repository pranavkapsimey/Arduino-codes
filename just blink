
#define soslight 13
void setup() {
  // initialize digital pin LED_BUILTIN as an output.
  pinMode(soslight, OUTPUT);
}

// the loop function runs over and over again forever
void loop() {
  digitalWrite(soslight, HIGH);  // turn the LED on (HIGH is the voltage level)
  delay(600);                      // wait for a second
  digitalWrite(soslight, LOW);   // turn the LED off by making the voltage LOW
  delay(200);                      // wait for a second
}
